# Virtual Environment
venv/

# Local data & uploads fallbacks (ignored as they are ephemeral/local)
uploads/
instance/
*.db

# Python cache & temporary files
__pycache__/
*.pyc

# Node dependencies & production builds
node_modules/
dist/
frontend/node_modules/
frontend/dist/

# IDE configurations & logs
.vscode/
.idea/
*.log

# Environment & Secrets (Crucial: ignore all env configs except the examples)
.env
.env.*
!.env.example
**/ .env
**/ .env.*
!**/ .env.example