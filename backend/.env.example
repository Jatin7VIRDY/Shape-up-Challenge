# Flask Environment Configuration
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# Database Configuration (Neon/Supabase/Local SQLite)
# For local SQLite, leave blank to use the default shapeup.db
DATABASE_URL=

# Cloudinary Configuration (Optional for cloud image/video storage)
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=
